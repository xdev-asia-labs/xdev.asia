    },
    "homepage": "https://xdev.asia",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "mcp",
        "xdev",
        "knowledge-base",
        "ai",
        "architecture",
        "devsecops",
        "programming",
        "vietnamese",
        "tutorials"
    ],
    "author": "xDev.asia",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "glob": "^11.0.0",
        "gray-matter": "^4.0.3"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.7.0"
    }
