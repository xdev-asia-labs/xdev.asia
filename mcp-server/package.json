{
    "name": "@xdev-asia/xdev-knowledge-mcp",
    "version": "0.0.0",
    "description": "MCP Server - Toàn bộ kiến thức xDev.asia: 57 series, 1200+ lessons, blog, showcase (AI, Architecture, DevSecOps, Programming)",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "xdev-knowledge-mcp": "dist/index.js"
    },
    "files": [
        "dist/",
        "content/",
        "data/",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "start": "node dist/index.js",
        "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
        "prebuild:publish": "node scripts/bundle-content.mjs",
        "build:publish": "npm run prebuild:publish && tsc"
    },
    "repository": {
        "type": "git",
